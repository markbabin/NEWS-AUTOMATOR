# Video input files
input/*
!input/.gitkeep

# Cached transcripts
transcripts/*
!transcripts/.gitkeep

# Video clips
clips/*
!clips/.gitkeep

# Excel output
output/*
!output/.gitkeep

# Python
__pycache__/
*.py[cod]
*.pyo
.DS_Store
venv/

# PyInstaller build artifacts
build/
dist/
*.spec

# Bundled binaries (platform-specific, not committed)
ffmpeg
ffprobe
ffmpeg.exe
ffprobe.exe

# App icon (optional, user-provided)
icon.icns
icon.ico

# MLX model cache
~/.cache/huggingface/
